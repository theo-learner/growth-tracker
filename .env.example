# Growth Tracker 환경변수 예시
# 실제 사용 시 .env.local로 복사하여 사용

# ── LLM 설정 (우선순위: LiteLLM > Anthropic 직접) ──────────────

# [옵션 1] LiteLLM 프록시 서버 (모든 LLM 모델 지원)
# LITELLM_API_BASE=http://localhost:4000
# LITELLM_API_KEY=your-litellm-key-here   # 인증 없으면 생략 가능
# LLM_MODEL=gpt-4o-mini                   # 생략 시 각 라우트 기본값 사용

# [옵션 2] Anthropic 직접 호출
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxx

# ── 앱 설정 ─────────────────────────────────────────────────────

# 온보딩 샘플 데이터 생성 여부 (true/false)
NEXT_PUBLIC_ENABLE_SAMPLE_DATA=true

# 개발 모드 플래그
NODE_ENV=production
